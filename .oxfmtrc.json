{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 120,
  "tabWidth": 2,
  "useTabs": false,
  "semi": false,
  "singleQuote": false,
  "quoteProps": "as-needed",
  "trailingComma": "all",
  "bracketSpacing": true,
  "arrowParens": "always",
  "endOfLine": "lf",
  "vueIndentScriptAndStyle": true,
  "ignorePatterns": [
    "dist",
    "public",
    ".local",
    "node_modules",
    "pnpm-lock.yaml",
    "release",
    "**/.vitepress/dist",
    "**/.vitepress/cache",
    "apps/frontend/src/typings/components.d.ts",
    "apps/frontend/src/router/elegant/*",
    "apps/frontend/src/typings/schema.d.ts",
    "apps/frontend/src/typings/i18n.d.ts"
  ]
}
