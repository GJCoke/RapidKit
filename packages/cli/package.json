{
  "name": "@rapidkit/cli",
  "version": "1.0.0",
  "private": true,
  "description": "Rapidkit — Monorepo development workflow CLI",
  "type": "module",
  "scripts": {
    "format": "oxfmt",
    "lint": "oxlint --fix",
    "dev": "tsx ../builder/cli.ts --dev",
