{
  "name": "rapidkit",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "check:format": "turbo format",
    "check:lint": "turbo lint",
    "check:spell": "cspell lint \"(packages|apps)/**/*.{js,ts,mjs,cjs,json,css,less,scss,vue,html,md}\"",
    "check:deps": "depcheck",
    "check:commit": "commitlint --edit $1",
    "check:types": "turbo typecheck",
    "commit": "git-cz",
    "prepare": "husky",
    "precommit": "lint-staged",
    "clean:workspace": "tsx ./scripts/clean-workspace.ts",
    "sync:version": "changeset version && tsx ./scripts/sync-changelogs.ts",
    "dev:frontend": "turbo build --filter !@rapidkit/frontend && turbo watch dev --filter @rapidkit/frontend",
    "dev:desktop": "turbo build --filter !@rapidkit/desktop && turbo watch dev --filter @rapidkit/desktop",
    "dev:backend": "pnpm --filter @rapidkit/backend dev",
    "dev:worker": "pnpm --filter @rapidkit/backend worker",
    "dev:beater": "pnpm --filter @rapidkit/backend beater",
    "dev:website": "turbo dev --filter @rapidkit/website",
    "rapidkit": "tsx packages/cli/src/index.ts"
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-git"
    }
  },
  "keywords": [],
  "author": "Coke <jock74608@gmail.com>",
  "license": "ISC",
  "packageManager": "pnpm@10.27.0",
  "engines": {
    "node": ">=24.11.0",
    "npm": ">=10.9.2",
    "pnpm": ">=10.20.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@commitlint/types": "^20.5.0",
    "@cspell/dict-python": "^4.2.26",
    "@cspell/dict-typescript": "^3.2.3",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.2",
    "@vitejs/plugin-vue": "^6.0.5",
    "commitizen": "^4.3.1",
    "cspell": "^10.0.0",
    "cz-git": "^1.12.0",
    "depcheck": "^1.4.7",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "openapi-typescript": "^7.13.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "turbo": "^2.9.4",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vue": "^3.5.32",
    "vue-eslint-parser": "^10.4.0"
  }
}
