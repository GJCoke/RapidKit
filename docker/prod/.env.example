# ============================================================
# Production Environment Variables
# Copy to .env.prod and fill in real values before deploying
# ============================================================

# --- Environment ---
ENVIRONMENT=PRODUCTION

# --- PostgreSQL ---
POSTGRESQL_ASYNC_SCHEME=postgresql+asyncpg
POSTGRESQL_SYNC_SCHEME=postgresql+psycopg
POSTGRESQL_USERNAME=root
POSTGRESQL_PASSWORD=CHANGE_ME_pg_password
POSTGRESQL_HOST=postgresql
POSTGRESQL_PORT=5432
POSTGRESQL_DATABASE=client

# --- Redis ---
REDIS_SCHEME=redis
REDIS_ROOT_PASSWORD=CHANGE_ME_redis_password
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_MAX_CONNECTIONS=10

# --- Celery ---
CELERY_REDIS_DATABASE=1
DATETIME_TIMEZONE=Asia/Shanghai

# --- MinIO ---
MINIO_ROOT_USER=root
MINIO_ROOT_PASSWORD=CHANGE_ME_minio_password

# --- Auth (REQUIRED in production) ---
ACCESS_TOKEN_KEY=CHANGE_ME_access_token_secret
REFRESH_TOKEN_KEY=CHANGE_ME_refresh_token_secret
RSA_PRIVATE_KEY=
RSA_PUBLIC_KEY=

# --- CORS ---
CORS_ORIGINS=["https://your-domain.com"]
CORS_HEADERS=["*"]

# --- Socket.IO Admin ---
SOCKETIO_ADMIN_USERNAME=admin
SOCKETIO_ADMIN_PASSWORD=CHANGE_ME_socketio_password
