{
  "name": "@rapidkit/backend",
  "version": "1.0.1",
  "scripts": {
    "postinstall": "uv sync",
    "format": "uv run ruff check --fix src && uv run ruff format src",
    "typecheck": "uv run ty check src",
    "dev": "uv run uvicorn src.main:app --reload --host 0.0.0.0 --port 16000",
    "worker": "uv run celery -A \"src.queues.app\" worker -l info",
    "beater": "uv run celery -A \"src.queues.app\" beat -S \"src.queues.scheduler:AsyncDatabaseScheduler\" -l info"
  },
  "engines": {
    "python": ">=3.14.0",
    "pip": ">=25.0.1"
  }
}
